generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMINISTRADOR
  GERENTE
  COZINHA
  PRODUCAO
  COMPRAS
  FINANCEIRO
  ESTOQUE
  CAIXA
  ATENDENTE
  PERSONALIZADO
}

enum MovimentacaoTipo {
  ENTRADA
  SAIDA
  AJUSTE
  PRODUCAO
}

enum ContaStatus {
  ABERTO
  PAGO
  ATRASADO
  CANCELADO
}

enum PedidoStatus {
  EM_PREPARO
  SAIU_ENTREGA
  ENTREGUE
  CANCELADO
}

enum OrdemStatus {
  AGUARDANDO
  EM_PREPARO
  CONCLUIDA
  CANCELADA
}

enum ProducaoReceitaStatus {
  EM_ANDAMENTO
  PAUSADA
  CONCLUIDA
  CANCELADA
}

enum CompraStatus {
  GERADO
  ENVIADO
  CONFIRMADO
  AGUARDANDO_ENTREGA
  PENDENTE
  PARCIAL
  RECEBIDO_PARCIALMENTE
  RECEBIDO
  DIVERGENTE
  CANCELADO
}

enum CotacaoStatus {
  RASCUNHO
  AGUARDANDO
  ENVIADA
  RESPONDIDA
  EM_ANALISE
  FINALIZADA
  VENCIDA
  ENCERRADA
  CANCELADA
}

enum ParticipacaoCotacaoStatus {
  LINK_NAO_ENVIADO
  ENVIADO
  ENTREGUE
  VISUALIZADO
  FALHA
  LINK_ACESSADO
  FORMULARIO_INICIADO
  RASCUNHO_SALVO
  RESPONDIDO
  RESPOSTA_ALTERADA
  VENCIDO
  RECUSADO
  CANCELADO
}

enum RecebimentoItemStatus {
  PENDENTE
  RECEBIDO_CORRETAMENTE
  RECEBIDO_PARCIALMENTE
  PRODUTO_DIVERGENTE
  QUANTIDADE_DIVERGENTE
  VALOR_DIVERGENTE
  PRODUTO_RECUSADO
  PRODUTO_AVARIADO
}

enum EntradaOrigem {
  MANUAL
  BOLETO
  XML
  PEDIDO_COMPRA
  AJUSTE
  PRODUCAO
}

model Usuario {
  id            String         @id @default(cuid())
  nome          String
  login         String?        @unique
  email         String         @unique
  senhaHash     String
  role          Role           @default(ESTOQUE)
  permissoes    String[]       @default([])
  funcionarioId String?        @unique
  funcionario   Funcionario?   @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)
  ativo         Boolean        @default(true)
  ultimoAcesso  DateTime?
  refreshTokens RefreshToken[]
  criadoEm      DateTime       @default(now())
  atualizadoEm  DateTime       @updatedAt
}

model Funcionario {
  id             String      @id @default(cuid())
  codigo         Int         @unique @default(autoincrement())
  nome           String
  cpf            String?     @unique
  rg             String?
  dataNascimento DateTime?
  dataAdmissao   DateTime?
  cargo          String
  setor          String
  telefone       String?
  email          String?
  endereco       String?
  salario        Decimal?    @db.Decimal(14, 2)
  ativo          Boolean     @default(true)
  observacoes    String?
  fotoUrl        String?
  usuario        Usuario?
  producoes      ProducaoReceita[]
  criadoEm       DateTime    @default(now())
  atualizadoEm   DateTime    @updatedAt

  @@index([nome])
  @@index([setor, cargo, ativo])
}
model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiraEm  DateTime
  revogadoEm DateTime?
  criadoEm  DateTime @default(now())
  @@index([usuarioId])
}

model Insumo {
  id            String         @id @default(cuid())
  codigo        String         @unique
  nome          String
  categoria     String
  unidade       String
  quantidade    Decimal        @default(0) @db.Decimal(14, 3)
  estoqueMinimo Decimal        @default(0) @db.Decimal(14, 3)
  custoUnitario Decimal        @default(0) @db.Decimal(14, 4)
  ativo         Boolean        @default(true)
  movimentacoes Movimentacao[]
  comprasManuais CompraManual[]
  entradasBoleto EntradaBoleto[]
  notasItens    NotaFiscalItem[]
  pedidoItens   PedidoCompraItem[]
  itensReceita  ItemReceita[]
  receitasProdutoFinal Receita[] @relation("ProdutoFinalReceita")
  cotacaoItens          CotacaoItem[]
  recebimentoItens     RecebimentoCompraItem[]
  historicoPrecos      HistoricoPrecoCompra[]
  ultimoFornecedorId  String?
  ultimoFornecedor    Fornecedor?              @relation("UltimoFornecedorInsumo", fields: [ultimoFornecedorId], references: [id], onDelete: SetNull)
  ultimaCompraEm       DateTime?
  ultimoCustoCompra    Decimal?                 @db.Decimal(14, 4)
  criadoEm      DateTime       @default(now())
  atualizadoEm  DateTime       @updatedAt
  @@index([nome])
  @@index([categoria, ativo])
}

model Movimentacao {
  id           String            @id @default(cuid())
  insumoId     String
  insumo       Insumo            @relation(fields: [insumoId], references: [id])
  tipo         MovimentacaoTipo
  origem       EntradaOrigem
  quantidade   Decimal           @db.Decimal(14, 3)
  saldoAnterior Decimal          @db.Decimal(14, 3)
  saldoPosterior Decimal         @db.Decimal(14, 3)
  custoUnitario Decimal?         @db.Decimal(14, 4)
  referenciaId String?
  descricao    String
  usuarioId    String?
  criadoEm     DateTime          @default(now())
  @@index([insumoId, criadoEm])
  @@index([origem, referenciaId])
}

model Fornecedor {
  id               String              @id @default(cuid())
  nome             String
  razaoSocial      String?
  nomeFantasia     String?
  cnpj             String?             @unique
  inscricaoEstadual String?
  email            String?
  telefone         String?
  whatsapp         String?
  site             String?
  endereco         String?
  cidade           String?
  estado           String?
  cep              String?
  contatoPrincipal String?
  categoria        String?
  formaPagamento  String?
  prazoPagamento  Int?
  observacao       String?
  avaliacao        Decimal?            @db.Decimal(3, 2)
  ativo          Boolean             @default(true)
  pedidos        PedidoCompra[]
  propostas      CotacaoFornecedor[]
  comprasManuais CompraManual[]
  entradasBoleto EntradaBoleto[]
  notasFiscais   NotaFiscalXml[]
  ultimoFornecedorDe Insumo[]              @relation("UltimoFornecedorInsumo")
  recebimentos        RecebimentoCompra[]
  historicoPrecos     HistoricoPrecoCompra[]
  criadoEm       DateTime            @default(now())
  atualizadoEm   DateTime            @updatedAt
  @@index([nome])
}

model CompraManual {
  id             String      @id @default(cuid())
  insumoId       String
  insumo         Insumo      @relation(fields: [insumoId], references: [id])
  quantidade     Decimal     @db.Decimal(14, 3)
  custoUnitario  Decimal     @db.Decimal(14, 4)
  fornecedorNome String
  fornecedorId   String?
  fornecedor     Fornecedor? @relation(fields: [fornecedorId], references: [id])
  formaPagamento String
  observacao     String?
  criadoEm       DateTime    @default(now())
  @@index([fornecedorId])
}

model EntradaBoleto {
  id             String      @id @default(cuid())
  insumoId       String
  insumo         Insumo      @relation(fields: [insumoId], references: [id])
  quantidade     Decimal     @db.Decimal(14, 3)
  fornecedorNome String
  fornecedorId   String?
  fornecedor     Fornecedor? @relation(fields: [fornecedorId], references: [id])
  linhaDigitavel String?
  valor          Decimal     @db.Decimal(14, 2)
  vencimento     DateTime
  contaPagar     ContaPagar?
  criadoEm       DateTime    @default(now())
  @@index([fornecedorId])
}

model NotaFiscalXml {
  id             String            @id @default(cuid())
  chave          String            @unique
  fornecedorNome String
  fornecedorId   String?
  fornecedor     Fornecedor?       @relation(fields: [fornecedorId], references: [id])
  cnpj           String?
  valorTotal     Decimal           @db.Decimal(14, 2)
  xmlOriginal    String?
  itens          NotaFiscalItem[]
  contasPagar    ContaPagar[]
  criadoEm       DateTime          @default(now())
  @@index([fornecedorId])
}

model NotaFiscalItem {
  id            String        @id @default(cuid())
  notaFiscalId  String
  notaFiscal    NotaFiscalXml @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)
  insumoId      String
  insumo        Insumo        @relation(fields: [insumoId], references: [id])
  codigoProduto String?
  descricao     String
  unidade       String
  quantidade    Decimal       @db.Decimal(14, 3)
  valorUnitario Decimal       @db.Decimal(14, 4)
  @@index([notaFiscalId])
}

model ContaPagar {
  id             String          @id @default(cuid())
  descricao      String
  fornecedorNome String?
  valor          Decimal         @db.Decimal(14, 2)
  vencimento     DateTime?
  status         ContaStatus     @default(ABERTO)
  linhaDigitavel String?
  entradaBoletoId String?        @unique
  entradaBoleto  EntradaBoleto?  @relation(fields: [entradaBoletoId], references: [id])
  notaFiscalId   String?
  notaFiscal     NotaFiscalXml?  @relation(fields: [notaFiscalId], references: [id])
  pedidoCompraId String?          @unique
  pedidoCompra   PedidoCompra?    @relation(fields: [pedidoCompraId], references: [id], onDelete: SetNull)
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt
  @@index([status, vencimento])
}

model ContaReceber {
  id           String      @id @default(cuid())
  descricao    String
  clienteNome  String?
  valor        Decimal     @db.Decimal(14, 2)
  vencimento   DateTime?
  status       ContaStatus @default(ABERTO)
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
}

model OrdemPreparo {
  id           String      @id @default(cuid())
  codigo       String      @unique
  produto      String
  quantidade   Decimal     @db.Decimal(14, 3)
  unidade      String
  responsavel  String?
  progresso    Int         @default(0)
  status       OrdemStatus @default(AGUARDANDO)
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
}

model Receita {
  id                  String            @id @default(cuid())
  codigo              String            @unique
  nome                String
  categoria           String?
  descricao           String?
  fotoUrl             String?
  rendimento          Decimal           @db.Decimal(14, 3)
  unidadeRendimento   String
  tempoPreparoMinutos Int?
  modoPreparo         String?
  custoEstimado       Decimal?          @db.Decimal(14, 4)
  observacoes         String?
  setorPadrao         String?
  instrucoesProducao  String?
  equipamentos        String?
  responsavelPadrao   String?
  etapas              Json?
  produtoFinalId      String?
  produtoFinal        Insumo?           @relation("ProdutoFinalReceita", fields: [produtoFinalId], references: [id], onDelete: SetNull)
  ativo               Boolean           @default(true)
  itens               ItemReceita[]
  producoes           ProducaoReceita[]
  criadoEm            DateTime          @default(now())
  atualizadoEm        DateTime          @updatedAt

  @@index([nome])
  @@index([categoria, ativo])
  @@index([produtoFinalId])
  @@map("receitas")
}

model ItemReceita {
  id             String   @id @default(cuid())
  receitaId      String
  receita        Receita  @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  insumoId       String?
  insumo         Insumo?  @relation(fields: [insumoId], references: [id], onDelete: SetNull)
  nome           String
  quantidade     Decimal  @db.Decimal(14, 3)
  unidade        String
  custoUnitario  Decimal? @db.Decimal(14, 4)
  criadoEm       DateTime @default(now())

  @@index([receitaId])
  @@index([insumoId])
  @@map("itens_receita")
}

model ProducaoReceita {
  id                   String                @id @default(cuid())
  receitaId            String
  receita              Receita               @relation(fields: [receitaId], references: [id])
  funcionarioId        String
  funcionario          Funcionario           @relation(fields: [funcionarioId], references: [id])
  quantidadeProduzida  Decimal               @db.Decimal(14, 3)
  unidade              String
  setor                String
  quantidadePerdida   Decimal               @default(0) @db.Decimal(14, 3)
  motivoPerda          String?
  dataProducao         DateTime
  horaInicio           DateTime?
  horaFim              DateTime?
  lote                 String?
  validade             DateTime?
  status               ProducaoReceitaStatus @default(EM_ANDAMENTO)
  observacoes          String?
  canceladaEm          DateTime?
  motivoCancelamento   String?
  estoqueProcessadoEm  DateTime?
  criadoEm             DateTime              @default(now())
  atualizadoEm         DateTime              @updatedAt

  @@index([receitaId, dataProducao])
  @@index([funcionarioId, dataProducao])
  @@index([status, dataProducao])
  @@map("producoes_receitas")
}
model Pedido {
  id             String       @id @default(cuid())
  codigo         String       @unique
  clienteNome    String
  endereco       String?
  formaPagamento String
  canal          String       @default("Direto")
  valorTotal     Decimal      @db.Decimal(14, 2)
  status         PedidoStatus @default(EM_PREPARO)
  itens          PedidoItem[]
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt
}

model PedidoItem {
  id          String  @id @default(cuid())
  pedidoId    String
  pedido      Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto     String
  quantidade  Decimal @db.Decimal(14, 3)
  valorUnitario Decimal @db.Decimal(14, 2)
}

model PedidoCompra {
  id                  String              @id @default(cuid())
  codigo              String              @unique
  cotacaoId           String?
  cotacao             Cotacao?            @relation(fields: [cotacaoId], references: [id], onDelete: SetNull)
  fornecedorId        String
  fornecedor          Fornecedor          @relation(fields: [fornecedorId], references: [id])
  status              CompraStatus        @default(GERADO)
  valorTotal          Decimal             @db.Decimal(14, 2)
  frete               Decimal             @default(0) @db.Decimal(14, 2)
  desconto            Decimal             @default(0) @db.Decimal(14, 2)
  acrescimos          Decimal             @default(0) @db.Decimal(14, 2)
  condicaoPagamento   String?
  formaPagamento      String?
  dataPrevistaEntrega DateTime?
  responsavelCompra   String?
  observacoes         String?
  finalizadoEm        DateTime?
  recebidoEm          DateTime?
  canceladoEm         DateTime?
  motivoCancelamento  String?
  pdfArquivo          Bytes?
  pdfNome             String?
  pdfGeradoEm         DateTime?
  pdfEnviadoWhatsappEm DateTime?
  pdfWhatsappMensagemId String?
  contaPagar          ContaPagar?
  itens               PedidoCompraItem[]
  recebimentos        RecebimentoCompra[]
  criadoEm            DateTime            @default(now())
  atualizadoEm        DateTime            @updatedAt

  @@index([cotacaoId])
  @@index([fornecedorId, status])
}

model PedidoCompraItem {
  id             String                  @id @default(cuid())
  pedidoCompraId String
  pedidoCompra   PedidoCompra            @relation(fields: [pedidoCompraId], references: [id], onDelete: Cascade)
  insumoId       String
  insumo         Insumo                  @relation(fields: [insumoId], references: [id])
  quantidade     Decimal                 @db.Decimal(14, 3)
  unidade        String?
  custoUnitario  Decimal                 @db.Decimal(14, 4)
  marca          String?
  embalagem      String?
  desconto       Decimal                 @default(0) @db.Decimal(14, 2)
  observacoes    String?
  recebimentos   RecebimentoCompraItem[]

  @@index([pedidoCompraId])
  @@index([insumoId])
}

model Cotacao {
  id                String              @id @default(cuid())
  codigo            String              @unique
  descricao         String
  quantidade        Decimal             @db.Decimal(14, 3)
  unidade           String
  insumoCodigo      String?
  estoqueAtual      Decimal?            @db.Decimal(14, 3)
  estoqueMinimo     Decimal?            @db.Decimal(14, 3)
  saldoCaixa        Decimal?            @db.Decimal(14, 2)
  status            CotacaoStatus       @default(AGUARDANDO)
  prazoResposta     DateTime?
  observacoes       String?
  finalizadaEm      DateTime?
  finalizadaPorId   String?
  motivoFinalizacao String?
  economiaTotal     Decimal?            @db.Decimal(14, 2)
  itens             CotacaoItem[]
  propostas         CotacaoFornecedor[]
  pedidos           PedidoCompra[]
  criadoEm          DateTime            @default(now())
  atualizadoEm      DateTime            @updatedAt

  @@index([status, prazoResposta])
}

model CotacaoItem {
  id                   String                @id @default(cuid())
  cotacaoId            String
  cotacao              Cotacao               @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  insumoId             String
  insumo               Insumo                @relation(fields: [insumoId], references: [id])
  quantidadeSolicitada Decimal               @db.Decimal(14, 3)
  unidade              String
  marcaPreferencial    String?
  embalagemSolicitada  String?
  observacoes          String?
  dataDesejadaEntrega  DateTime?
  ultimoPreco          Decimal?              @db.Decimal(14, 4)
  propostas            CotacaoItemProposta[]
  criadoEm             DateTime              @default(now())

  @@unique([cotacaoId, insumoId])
  @@index([insumoId])
}

model CotacaoFornecedor {
  id                  String                    @id @default(cuid())
  cotacaoId           String
  cotacao             Cotacao                   @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  fornecedorId        String
  fornecedor          Fornecedor                @relation(fields: [fornecedorId], references: [id])
  status              ParticipacaoCotacaoStatus @default(LINK_NAO_ENVIADO)
  tokenPublico        String?                   @unique
  tokenValidoAte      DateTime?
  tokenCanceladoEm    DateTime?
  precoUnitario       Decimal?                  @db.Decimal(14, 4)
  prazoDias           Int?
  frete               Decimal?                  @db.Decimal(14, 2)
  desconto            Decimal?                  @db.Decimal(14, 2)
  acrescimos          Decimal?                  @db.Decimal(14, 2)
  valorMinimoPedido   Decimal?                  @db.Decimal(14, 2)
  freteGratisAcima    Decimal?                  @db.Decimal(14, 2)
  condicoes           String?
  formaPagamento      String?
  prazoPagamento      Int?
  detalhesPagamento   Json?
  diasEntrega         String[]                  @default([])
  periodoEntrega      String?
  dataMaisProximaEntrega DateTime?
  dataLimitePedido    DateTime?
  validadeProposta    DateTime?
  impostoIncluso      Boolean?
  responsavelNome     String?
  responsavelTelefone String?
  observacoesGerais   String?
  anexos              Json?
  origemResposta      String?
  whatsappMensagemId  String?                   @unique
  numeroWhatsappEnvio String?
  enviadaEm           DateTime?
  entregueEm          DateTime?
  visualizadaEm       DateTime?
  falhaEnvio          String?
  acessadaEm          DateTime?
  iniciadaEm          DateTime?
  rascunhoEm          DateTime?
  respondidaEm        DateTime?
  respostaOriginal    String?
  ipResposta          String?
  versao              Int                       @default(1)
  bloqueada           Boolean                   @default(false)
  recusadaEm          DateTime?
  motivoRecusa        String?
  detalheRecusa       String?
  selecionada         Boolean                   @default(false)
  itens               CotacaoItemProposta[]
  acessos             CotacaoAcesso[]

  @@unique([cotacaoId, fornecedorId])
  @@index([status, tokenValidoAte])
}

model CotacaoItemProposta {
  id                  String            @id @default(cuid())
  participacaoId      String
  participacao        CotacaoFornecedor @relation(fields: [participacaoId], references: [id], onDelete: Cascade)
  cotacaoItemId       String
  cotacaoItem         CotacaoItem       @relation(fields: [cotacaoItemId], references: [id], onDelete: Cascade)
  disponivel          Boolean           @default(true)
  precoUnitario       Decimal?          @db.Decimal(14, 4)
  marcaOferecida      String?
  embalagem           String?
  quantidadeEmbalagem Decimal?          @db.Decimal(14, 3)
  quantidadeMinima    Decimal?          @db.Decimal(14, 3)
  quantidadeMinimaEmbalagem Decimal?     @db.Decimal(14, 3)
  prazoDias           Int?
  dataPrevistaEntrega DateTime?
  observacoes         String?
  valorTotal          Decimal?          @db.Decimal(14, 2)
  selecionada         Boolean           @default(false)
  atualizadoEm        DateTime          @updatedAt

  @@unique([participacaoId, cotacaoItemId])
  @@index([cotacaoItemId])
}

model CotacaoAcesso {
  id             String            @id @default(cuid())
  participacaoId String
  participacao   CotacaoFornecedor @relation(fields: [participacaoId], references: [id], onDelete: Cascade)
  ip             String?
  userAgent      String?
  criadoEm       DateTime          @default(now())

  @@index([participacaoId, criadoEm])
}

model RecebimentoCompra {
  id                     String                  @id @default(cuid())
  pedidoCompraId         String
  pedidoCompra           PedidoCompra            @relation(fields: [pedidoCompraId], references: [id], onDelete: Restrict)
  fornecedorId           String
  fornecedor             Fornecedor              @relation(fields: [fornecedorId], references: [id])
  numeroNotaFiscal       String?
  serieNotaFiscal        String?
  chaveAcesso            String?                 @unique
  dataEmissao            DateTime?
  dataEntrada            DateTime?
  valorProdutos          Decimal?                @db.Decimal(14, 2)
  frete                  Decimal?                @db.Decimal(14, 2)
  desconto               Decimal?                @db.Decimal(14, 2)
  impostos               Decimal?                @db.Decimal(14, 2)
  valorTotal             Decimal?                @db.Decimal(14, 2)
  anexosNota             Json?
  observacoes            String?
  status                 CompraStatus            @default(PENDENTE)
  estoqueConfirmadoEm    DateTime?
  estoqueConfirmadoPorId String?
  criadoPorId            String?
  itens                  RecebimentoCompraItem[]
  criadoEm               DateTime                @default(now())
  atualizadoEm           DateTime                @updatedAt

  @@index([pedidoCompraId, status])
}

model RecebimentoCompraItem {
  id                    String                @id @default(cuid())
  recebimentoId         String
  recebimento           RecebimentoCompra     @relation(fields: [recebimentoId], references: [id], onDelete: Cascade)
  pedidoCompraItemId    String
  pedidoCompraItem      PedidoCompraItem      @relation(fields: [pedidoCompraItemId], references: [id])
  insumoId              String
  insumo                Insumo                @relation(fields: [insumoId], references: [id])
  quantidadePedida      Decimal               @db.Decimal(14, 3)
  quantidadeRecebida    Decimal               @db.Decimal(14, 3)
  quantidadeRecusada    Decimal               @default(0) @db.Decimal(14, 3)
  fatorConversaoEstoque Decimal               @default(1) @db.Decimal(14, 4)
  unidade               String
  lote                  String?
  dataFabricacao        DateTime?
  dataValidade          DateTime?
  valorUnitarioRecebido Decimal               @db.Decimal(14, 4)
  marcaRecebida         String?
  situacao              RecebimentoItemStatus @default(PENDENTE)
  observacoes           String?

  @@index([recebimentoId])
  @@index([insumoId])
}

model HistoricoPrecoCompra {
  id               String     @id @default(cuid())
  insumoId         String
  insumo           Insumo     @relation(fields: [insumoId], references: [id])
  fornecedorId     String
  fornecedor       Fornecedor @relation(fields: [fornecedorId], references: [id])
  quantidade       Decimal    @db.Decimal(14, 3)
  unidade          String
  precoUnitario    Decimal    @db.Decimal(14, 4)
  frete            Decimal    @default(0) @db.Decimal(14, 2)
  desconto         Decimal    @default(0) @db.Decimal(14, 2)
  custoFinal       Decimal    @db.Decimal(14, 4)
  cotacaoCodigo    String?
  pedidoCodigo     String?
  notaFiscalNumero String?
  usuarioId        String?
  criadoEm         DateTime   @default(now())

  @@index([insumoId, criadoEm])
  @@index([fornecedorId, criadoEm])
}

model CompraAuditoria {
  id         String   @id @default(cuid())
  entidade   String
  entidadeId String
  acao       String
  usuarioId  String?
  detalhes   Json?
  criadoEm   DateTime @default(now())

  @@index([entidade, entidadeId, criadoEm])
}

model CredencialIntegracao {
  id             String    @id @default(cuid())
  plataforma     String    @unique
  identificador  String?
  segredoCifrado String
  iv             String
  authTag        String
  verificadoEm   DateTime?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt
}
model WebhookWhatsapp {
  id          String   @id @default(cuid())
  mensagemId  String   @unique
  telefone    String
  texto       String?
  payload     Json
  processadoEm DateTime @default(now())
}
